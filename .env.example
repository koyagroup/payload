# Core app
DATABASE_URL=postgresql://koya_app:replace-me@db.koyabank.com:5432/koya_payload
PAYLOAD_SECRET=replace-with-strong-random-secret
NEXT_PUBLIC_SERVER_URL=https://payload.koyabank.com
# Optional local-only schema push (default false; prefer migrations)
PAYLOAD_PUSH_SCHEMA=false
# Admin-level connection used to create additional databases (like seed DB)
DATABASE_ADMIN_URL=postgresql://postgres:replace-me@db.koyabank.com:5432/postgres
# Seed database options
SEED_DATABASE_NAME=koya_payload_seed
SEED_DATABASE_URL=postgresql://koya_app:replace-me@db.koyabank.com:5432/koya_payload_seed

# Optional: Vercel Blob (recommended in production)
# If empty, media falls back to local disk storage.
BLOB_READ_WRITE_TOKEN=

# Preview integration (Payload -> Koya preview endpoint)
KOYA_PREVIEW_URL=http://localhost:3001/api/preview
KOYA_PREVIEW_SECRET=replace-with-preview-secret

# Publish webhook integration (Payload -> Koya revalidation endpoint)
KOYA_REVALIDATE_WEBHOOK_URL=http://localhost:3001/api/revalidate
KOYA_REVALIDATE_WEBHOOK_SECRET=replace-with-webhook-secret
KOYA_REVALIDATE_TIMEOUT_MS=5000

# Optional seed users
SEED_ADMIN_EMAIL=admin@koya.app
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_EDITOR_EMAIL=editor@koya.app
SEED_EDITOR_PASSWORD=ChangeMe123!
SEED_PUBLISHER_EMAIL=publisher@koya.app
SEED_PUBLISHER_PASSWORD=ChangeMe123!
